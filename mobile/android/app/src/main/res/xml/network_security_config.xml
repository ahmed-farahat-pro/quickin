<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow plain-HTTP only to the local Next.js dev API server. 10.0.2.2 is the host
         machine as seen from the Android emulator (the default debug DEV_API_BASE_URL is
         http://10.0.2.2:3000). All production / verification traffic goes over HTTPS. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
