# QuickIn — local stack env (no Supabase). Copy to .env.local and fill in.

# Postgres (local dev default shown; set to your Neon/Vercel URL in prod)
DATABASE_URL=postgresql://ahmedfarahat@127.0.0.1:5432/quickin_local

# Secret used to sign auth tokens (HMAC). Change in production.
AUTH_SECRET=change-me-in-production

# Egyptian ID OCR service (the Python StructOCR proxy). Web /api/id-scan forwards here.
ID_OCR_URL=http://localhost:8000

# Google sign-in (optional; leave blank to hide the button)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ---- Email / OTP (signup verification codes) --------------------------------
# When unset, OTP codes are logged to the server console (dev). Set these to send
# real email via SMTP (implicit TLS, port 465 — e.g. Gmail app password).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="QuickIn <no-reply@quickin.app>"
