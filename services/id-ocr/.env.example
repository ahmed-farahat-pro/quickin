# StructOCR Egyptian National ID OCR — server config.
# Copy this file to `.env` (same folder) and fill in your key, then restart the server.
#
# Get a key (20 free credits on signup; each ID scan costs 2 credits):
#   https://structocr.com  ->  Dashboard  ->  API Management
STRUCTOCR_API_KEY=

# Defaults below are fine — override only if needed.
STRUCTOCR_API_URL=https://api.structocr.com/v1/national-id
STRUCTOCR_MAX_DIM=1920
STRUCTOCR_JPEG_QUALITY=85
STRUCTOCR_TIMEOUT=30
