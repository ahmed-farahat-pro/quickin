<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow plain-HTTP to local dev servers (Supabase API + the Egyptian ID OCR
         service on :8000). 10.0.2.2 is the host machine as seen from the Android
         emulator; 192.168.8.24 is the dev Mac's LAN IP for testing on a real device
         over Wi-Fi (must match IDScanService.BASE_URL / the Mac's current IP). -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">192.168.8.24</domain>
    </domain-config>
</network-security-config>
